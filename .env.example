# HTTP bind address for the dashboard and API
PHASR_ADDR=127.0.0.1:7777

# Root directory for task metadata, logs, worktrees, and optional presets file
# Use ~/.phasr (legacy ~/.staq is no longer used).
PHASR_DATA_DIR=~/.phasr

# Default editor used by "Open Editor" actions
# Supported shortcuts: code, cursor, zed, vim, nvim, open
PHASR_DEFAULT_EDITOR=code
